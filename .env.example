# Open Dataroom — Environment Variables
# Copy this file to .env and fill in your values.

# ── Supabase ─────────────────────────────────────────────────
# Find these at: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Password Gate ────────────────────────────────────────────
# SHA-256 hash of the access code visitors must enter.
# Generate it: echo -n "your-password" | shasum -a 256
INVESTOR_PASSWORD_HASH=your-sha256-hash-here

# ── Email Notifications ──────────────────────────────────────
# Get a free API key at: https://resend.com
RESEND_API_KEY=re_your_resend_api_key

# Email address that receives session summary notifications
NOTIFY_EMAIL=you@yourcompany.com

# ── Google OAuth (optional) ──────────────────────────────────
# Required only if you want Google SSO login.
# Set up at: https://supabase.com/dashboard/project/YOUR_PROJECT/auth/providers
# Then configure in Google Cloud Console:
# - Authorized redirect URI: https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
